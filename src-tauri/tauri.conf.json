{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thirty-Minute Brain",
  "version": "0.1.0",
  "identifier": "com.thirtyminutebrain.app",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Thirty-Minute Brain",
        "width": 900,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

